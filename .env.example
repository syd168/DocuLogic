# ========== Docker 部署配置（仅 Docker 使用）==========
# 以下配置项仅在 docker-compose.yml 中使用，本地开发无需关注
#
# 数据根目录（所有持久化数据的父目录）
# 默认: ~/doculogic/data
# 示例: /mnt/storage/doculogic/data
# 
# 目录结构:
#   ${DATA_DIR}/
#   ├── output/          # 文档解析输出
#   ├── logs/            # 应用日志
#   ├── database/        # 数据库文件
#   │   ├── sqlite/      # SQLite
#   │   ├── mysql/       # MySQL
#   │   ├── mariadb/     # MariaDB
#   │   └── postgresql/  # PostgreSQL
#   └── backups/         # 数据库备份
DATA_DIR=~/doculogic/data

# 模型权重目录
# 默认: ~/doculogic/weights
# 示例: /data/weights
MODEL_DIR=~/doculogic/weights

# 前端访问端口（Docker 宿主机映射端口）
HOST_PORT=8030

# GPU 数量（多卡环境可调整）
GPU_COUNT=1

# 内存限制（Docker 容器最大可用内存，如 4g、8g、16g）
MEM_LIMIT=16g

# CPU 限制（Docker 容器最大可用 CPU 核心数，如 2.0、4.0、8.0）
CPU_LIMIT=4.0

# ========== 应用配置（Docker 和本地通用）==========
# 以下配置项在 Docker 和本地开发环境中都会使用
#
# 📌 文档解析器自动发现机制（推荐）
# 
# 系统启动时会自动：
#   1. 扫描 converts/plugins/ 目录并加载所有可用文档解析器插件
#   2. 自动发现模型文件位置
#
# 模型路径规则（约定优于配置）：
#   - 本地开发: 项目根目录/weights/<engine_id>
#   - Docker部署: /app/weights/<engine_id>
#
# 示例：
#   - logics-parsing-v2 → weights/logics-parsing-v2


# 解析任务输出根目录（未在系统设置里指定时使用；默认项目根下 out/）
# OUTPUT_DIR=out

# ========== 安全配置（Docker 和本地通用，生产环境务必修改）==========
# JWT_SECRET: 用于签名 JWT Token，建议使用 64 字符的随机十六进制字符串
# 生成命令: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# CODE_PEPPER: 验证码加盐值，用于增强验证码安全性
# 生成命令: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
CODE_PEPPER=aVeryComplexSecretSaltValueForEmailVerification2024!@#$

# 运行环境（可选值: development | production | prod）
# - development: 开发环境，使用默认 JWT_SECRET 仅警告不阻止启动
# - production/prod: 生产环境，使用默认 JWT_SECRET 将强制阻止启动
# ENVIRONMENT=development

# ========== 数据库配置（Docker 和本地通用）==========
# 支持四种数据库：SQLite（默认）、MySQL、MariaDB、PostgreSQL
#
# 只需修改 DATABASE_TYPE 即可切换数据库，其他配置项保持激活状态
DATABASE_TYPE=sqlite          # 可选值: sqlite | mysql | mariadb | postgresql
#
#
#
# SQLite 配置（当 DATABASE_TYPE=sqlite 时自动使用）
DATABASE_URL=sqlite:///web/data/app.db
#
#
#
# MySQL / MariaDB 配置（当 DATABASE_TYPE=mysql 或 mariadb 时自动读取）
#   - Docker 部署：MySQL/MariaDB 容器会自动创建，MYSQL_HOST 改为 mysql/mariadb
#   - 本地部署：需先安装 MySQL/MariaDB 并创建数据库，MYSQL_HOST 保持 localhost
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root                   # 应用连接使用的用户（Docker 部署时会创建 doculogic 用户）
MYSQL_PASSWORD=doculogic123
MYSQL_DATABASE=doculogic
MYSQL_APP_USER=doculogic          # Docker 中创建的普通用户（不能是 root）
#
#
#
# PostgreSQL 配置（当 DATABASE_TYPE=postgresql 时自动读取）
#   - Docker 部署：PostgreSQL 容器会自动创建，PG_HOST 改为 postgresql
#   - 本地部署：需先安装 PostgreSQL 并创建数据库，PG_HOST 保持 localhost
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=doculogic

# ========== 邮件配置（Docker 和本地通用）==========
# 邮件：开发默认不写 SMTP，验证码打印在服务端控制台（EMAIL_MOCK=true）
EMAIL_MOCK=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# 短信 HTTP（可在管理后台配置；存库优先，此处为回退）
# SMS_HTTP_URL=https://your-provider.example/send
# SMS_HTTP_SECRET=
# SMS_HTTP_TIMEOUT=15

# ========== 应用行为配置（Docker 和本地通用）==========
# 验证码有效期（分钟）
CODE_EXPIRE_MINUTES=10

# CORS（逗号分隔；须与浏览器地址栏「来源」完全一致，含端口）
# 本地前后端分离：dev/preview 端口；Docker 单容器 Nginx 对外默认 8030 时请加 http://localhost:8030 等
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:8030,http://localhost:8030

# 后端监听端口（web_server.py / uvicorn）
BACKEND_PORT=8000

# 管理员用户名（逗号分隔，启动时标记为 is_admin，可编辑系统设置与下载模型）
#ADMIN_USERNAMES=alice

# 首次启动且数据库中尚无用户名为 admin 的账号时，会自动创建默认管理员：用户名 admin，密码 admin123（请登录后立即修改）

# 无本地模型时仍启动 API（便于 Docker 先起服务再在后台下载模型）
ALLOW_START_WITHOUT_MODEL=1

# 系统设置里允许的输出/模型路径前缀（逗号分隔绝对路径，Docker 可设为 /data,/weights）
SETTINGS_PATH_ALLOW_PREFIXES=/data,/weights

# PDF 最大解析页数
PDF_MAX_PAGES=80

# ========== Redis 缓存配置（Docker 和本地通用）==========
# Redis 缓存配置（Docker 部署时自动启用）
# 本地部署如不使用 Redis，可注释掉以下配置，系统将自动降级到数据库
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # 如果需要密码认证，取消注释并设置

# ========== 调试配置（Docker 和本地通用）==========
# 解析失败时是否保留任务目录（上传与中间文件）；默认不保留以免占满磁盘。排查推理错误时可设为 1
# KEEP_FAILED_JOB_ARTIFACTS=1

# ========== Nginx 配置（仅 Docker 使用）==========
# Nginx 最大请求体大小（比后端配置大 10%）
# 后端配置在管理后台设置（默认 50MB）
NGINX_MAX_BODY_SIZE=55m

# 后端允许的最大上传大小限制（MB）
# 管理后台设置的 max_upload_size_mb 不能超过此值
# MAX_UPLOAD_SIZE_MB=500
