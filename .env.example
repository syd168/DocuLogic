# 模型权重目录（可选配置）
# 默认自动检测顺序：
#   1. ./weights/ （项目根目录下的 weights 文件夹，推荐）
#   2. ./logics-parsingv2/weights/Logics-Parsing-v2 （旧版结构）
#   3. 本环境变量 MODEL_PATH（最高优先级，会覆盖以上默认值）
#
# 如果需要自定义路径，取消下面注释并修改：
# MODEL_PATH=/absolute/path/to/your/model
# 或相对路径（相对于 logics-parsingv2/ 文件夹）：
# MODEL_PATH=weights/Logics-Parsing-v2

# 解析任务输出根目录（未在系统设置里指定时使用；默认项目根下 out/）
# OUTPUT_DIR=out

# 安全（生产环境务必修改）
JWT_SECRET=请替换为随机长字符串
CODE_PEPPER=可选与JWT不同的盐用于邮箱验证码哈希

# 数据库（默认 SQLite）
# DATABASE_URL=sqlite:///.../web/data/app.db

# 邮件：可在管理后台「系统设置」中配置 SMTP（存 app_settings）；以下为环境变量回退
# 开发默认不写 SMTP，验证码打印在服务端控制台（EMAIL_MOCK=true）
EMAIL_MOCK=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# 短信 HTTP（可在管理后台配置；存库优先，此处为回退）
# SMS_HTTP_URL=https://your-provider.example/send
# SMS_HTTP_SECRET=
# SMS_HTTP_TIMEOUT=15

# 验证码有效期（分钟）
CODE_EXPIRE_MINUTES=10

# CORS（逗号分隔；前后端分离时包含前端 dev/preview 端口）
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173

# 后端监听端口（web_server.py / uvicorn）
# BACKEND_PORT=8000

# 管理员用户名（逗号分隔，启动时标记为 is_admin，可编辑系统设置与下载模型）
# ADMIN_USERNAMES=alice

# 首次启动且数据库中尚无用户名为 admin 的账号时，会自动创建默认管理员：用户名 admin，密码 admin123（请登录后立即修改）

# 无本地模型时仍启动 API（便于 Docker 先起服务再在后台下载模型）
# ALLOW_START_WITHOUT_MODEL=1

# 系统设置里允许的输出/模型路径前缀（逗号分隔绝对路径，Docker 可设为 /data,/models）
# SETTINGS_PATH_ALLOW_PREFIXES=/data,/models

# PDF 最大解析页数
PDF_MAX_PAGES=80

# 解析失败时是否保留任务目录（上传与中间文件）；默认不保留以免占满磁盘。排查推理错误时可设为 1
# KEEP_FAILED_JOB_ARTIFACTS=1
