    "labels": {
      "runtime_mode": "运行模式",
      "api_url": "API 地址",
      "access_token": "访问令牌",
      "timeout_seconds": "超时秒数",
      "use_doc_unwarping": "文档去扭曲",
      "use_doc_orientation_classify": "方向分类",
      "visualize": "返回可视化结果",
